---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@consts";
---

<PageLayout
  title="Impressum"
  description="Impressum gemäß § 5 DDG."
  noindex={true}
  lang="de"
>
  <Container>
    <article>
      <h1>Impressum</h1>

      <h2>Anbieter</h2>
      <p>
        Philipp Kuhnhardt<br />
        Bebelstr. 52<br />
        70193 Stuttgart
      </p>

      <h2>Kontakt</h2>
      <p>
        E-Mail: <Link href={`mailto:${SITE.EMAIL}`}>{SITE.EMAIL}</Link>
      </p>

      <form
        action="https://formspree.io/f/mkoyplaz"
        method="POST"
        class="not-prose my-6 flex flex-col gap-3"
      >
        <label class="flex flex-col gap-1 text-sm">
          <span>Ihre E-Mail-Adresse</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="rounded border border-black/15 bg-white/50 px-3 py-2 text-black dark:border-white/20 dark:bg-black/20 dark:text-white"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Betreff</span>
          <input
            type="text"
            name="subject"
            class="rounded border border-black/15 bg-white/50 px-3 py-2 text-black dark:border-white/20 dark:bg-black/20 dark:text-white"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Ihre Nachricht</span>
          <textarea
            name="message"
            rows="6"
            required
            class="resize-y rounded border border-black/15 bg-white/50 px-3 py-2 text-black dark:border-white/20 dark:bg-black/20 dark:text-white"
          ></textarea>
        </label>
        <input
          type="text"
          name="_gotcha"
          tabindex="-1"
          autocomplete="off"
          class="hidden"
        />
        <button
          type="submit"
          class="self-start rounded border border-black/20 px-4 py-2 text-sm transition-colors duration-300 ease-in-out hover:text-black dark:border-white/30 dark:hover:text-white"
        >
          Nachricht senden
        </button>
      </form>

      <p>
        <Link href="/legal/datenschutzerklaerung/">Datenschutzerklärung</Link>
      </p>
    </article>
  </Container>
</PageLayout>
