---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout
  title="Impressum"
  description="Impressum gemäß § 5 DDG."
  noindex={true}
  lang="de"
>
  <Container>
    <article>
      <h1>Impressum</h1>

      <p>
        Philipp Kuhnhardt<br />
        Bebelstr. 52<br />
        70193 Stuttgart
      </p>

      <h2>Kontakt</h2>
      <p>
        E-Mail: philipps.blog@posteo.de<br />
        Über das nachfolgende Formular erreichen Sie mich ebenfalls.
      </p>

      <form
        action="https://formspree.io/f/mkoyplaz"
        method="POST"
        class="not-prose flex flex-col gap-3 my-6"
      >
        <label class="flex flex-col gap-1 text-sm">
          <span>Ihre E-Mail-Adresse</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="px-3 py-2 rounded border border-black/15 dark:border-white/20 bg-white/50 dark:bg-black/20 text-black dark:text-white"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Betreff</span>
          <input
            type="text"
            name="subject"
            class="px-3 py-2 rounded border border-black/15 dark:border-white/20 bg-white/50 dark:bg-black/20 text-black dark:text-white"
          />
        </label>
        <label class="flex flex-col gap-1 text-sm">
          <span>Ihre Nachricht</span>
          <textarea
            name="message"
            rows="6"
            required
            class="px-3 py-2 rounded border border-black/15 dark:border-white/20 bg-white/50 dark:bg-black/20 text-black dark:text-white resize-y"
          ></textarea>
        </label>
        <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" />
        <button
          type="submit"
          class="self-start px-4 py-2 rounded border border-black/20 dark:border-white/30 hover:text-black dark:hover:text-white transition-colors duration-300 ease-in-out cursor-pointer text-sm"
        >
          Nachricht senden
        </button>
      </form>

      <h2>Redaktionell verantwortlich</h2>
      <p>
        Philipp Kuhnhardt<br />
        Bebelstr. 52, 70193 Stuttgart
      </p>

      <p>
        Quelle: <Link href="https://www.e-recht24.de" external>eRecht24</Link>
      </p>

      <p>
        <Link href="/legal/datenschutz">Datenschutzerklärung</Link>
      </p>
    </article>
  </Container>
</PageLayout>
